{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "launchfly-db",
      "database_id": "a8d71563-4e5a-4509-a1b0-2b5a8cd765ad"
    }
  ],
  "routes": [
    { "pattern": "launchfly.io", "custom_domain": true },
    { "pattern": "www.launchfly.io", "custom_domain": true }
  ]
}
